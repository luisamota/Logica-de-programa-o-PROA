Algoritmo "4.59 - triangulo_angulos"
// Disciplina   : [Linguagem e Lógica de Programaçăo com VisualG]
// Professor   : Jailson
// Descriçăo   : Classifica o triângulo pelos ângulos
// Autor(a)    : Maria Luisa Mota
// Data atual  : 21/04/2026

Var
// Seçăo de Declaraçőes das variáveis
a, b, c: real

Inicio
// Seçăo de Comandos

Escreval("Digite os tręs ângulos: ")
leia(a, b, c)

se (a = 90) ou (b = 90) ou (c = 90) entao
   Escreval("Triângulo Retângulo")
senao
   se (a > 90) ou (b > 90) ou (c > 90) entao
      Escreval("Triângulo Obtusângulo")
   senao
      Escreval("Triângulo Acutângulo")
   fimse
fimse

Fimalgoritmo
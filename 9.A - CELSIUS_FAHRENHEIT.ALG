Algoritmo "9.a - celsius_fahrenheit"
// Disciplina   : [Lógica]
// Descriçăo    : Converte Celsius para Fahrenheit
// Autor(a)     : Maria Luisa Mota

Var
c, f: real

Inicio

Escreval("Digite a temperatura em Celsius: ")
leia(c)

f <- (c * 9/5) + 32

Escreval("Fahrenheit: ", f:0:2)

Fimalgoritmo
Algoritmo "7.03 - laboratorio"
// Disciplina   : [Linguagem e Lógica de Programaçăo com VisualG]
// Professor    : Jailson
// Descriçăo    : Controla acesso ao laboratório
// Autor(a)     : Maria Luisa Mota
// Data atual   : 21/04/2026

Var
agendamento, professor, manutencao: logico

Inicio

Escreval("Possui agendamento (V/F)? ")
leia(agendamento)

Escreval("Professor presente (V/F)? ")
leia(professor)

Escreval("Laboratório em manutençăo (V/F)? ")
leia(manutencao)

se ((agendamento ou professor) e (nao manutencao)) entao
   Escreval("Acesso Autorizado")
senao
   Escreval("Acesso Negado")
fimse

Fimalgoritmo